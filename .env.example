# ============================================================
# Weix 微信自动回复机器人 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ---------- 必填项 ----------

# DeepSeek API Key（或其他 AI provider 的 key）
DEEPSEEK_API_KEY=sk-your-key-here

# ---------- 安全配置（生产环境务必修改） ----------

# JWT 令牌签名密钥（请使用随机字符串）
JWT_SECRET=change-me-to-a-random-string

# 管理员密码
ADMIN_PASSWORD=admin123

# ---------- 可选配置 ----------

# 高德地图 API Key
AMAP_KEY=

# 高德地图安全密钥
AMAP_SECURITY_KEY=

# 自定义配置文件路径（默认 config/config.yaml）
# WEIX_CONFIG=config/config.yaml
